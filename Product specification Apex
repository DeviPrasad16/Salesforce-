public without sharing class ProductController {

    @AuraEnabled(cacheable=true)
    public static ProductResponse getProductDetails(Id productId) {

        if (productId == null) {
            throw new AuraHandledException('Invalid Product ID provided.');
        }

        try {

            Map<String, Schema.SObjectField> fieldsMap =
                Product2.SObjectType.getDescribe().fields.getMap();

            List<String> fieldsToQuery = new List<String>{
                'Id',
                'Name',
                'Description',
                'ProductCode',
                'StockKeepingUnit'
            };

          
            for(String fieldName : fieldsMap.keySet()) {

                Schema.DescribeFieldResult data =
                    fieldsMap.get(fieldName).getDescribe();

                if(
                    data.isAccessible() &&
                    data.isCustom()
                ) {
                    fieldsToQuery.add(fieldName);
                }
            }

            String soql =
                'SELECT ' +
                String.join(fieldsToQuery, ',') +
                ' FROM Product2 ' +
                ' WHERE Id = :productId ' +
                ' LIMIT 1';

            System.debug('SOQL => ' + soql);

            Product2 product = Database.query(soql);

            ProductResponse response = new ProductResponse();

            response.id = product.Id;
            response.name = product.Name;
            response.description = product.Description;
            response.specifications = new List<SpecRow>();

           
            if(String.isNotBlank(product.StockKeepingUnit)) {
                response.specifications.add(
                    createSpec(
                        'SKU',
                        product.StockKeepingUnit
                    )
                );
            }

         
            if(String.isNotBlank(product.ProductCode)) {
                response.specifications.add(
                    createSpec(
                        'Item Number',
                        product.ProductCode
                    )
                );
            }

            List<String> sortedFields = new List<String>();

            for(String fieldName : fieldsMap.keySet()) {

                Schema.DescribeFieldResult data =
                    fieldsMap.get(fieldName).getDescribe();

                if(
                    data.isAccessible() &&
                    data.isCustom()
                ) {
                    sortedFields.add(fieldName);
                }
            }

            sortedFields.sort();

            for(String fieldName : sortedFields) {

                try {

                    Object rawValue =
                        product.get(fieldName);

                    if(rawValue == null) {
                        continue;
                    }

                    String value =
                        String.valueOf(rawValue).trim();

                    if(String.isBlank(value)) {
                        continue;
                    }

                    response.specifications.add(
                        createSpec(
                            fieldsMap.get(fieldName)
                                     .getDescribe()
                                     .getLabel(),
                            value
                        )
                    );

                } catch(Exception ex) {

                    System.debug(
                        'Skipping field: ' +
                        fieldName +
                        ' Error: ' +
                        ex.getMessage()
                    );
                }
            }

            return response;

        } catch(Exception e) {

            throw new AuraHandledException(
                'An unexpected error occurred: ' +
                e.getMessage()
            );
        }
    }

    private static SpecRow createSpec(
        String label,
        String value
    ) {
        SpecRow row = new SpecRow();
        row.label = label;
        row.value = value;
        return row;
    }

    public class ProductResponse {

        @AuraEnabled
        public Id id;

        @AuraEnabled
        public String name;

        @AuraEnabled
        public String description;

        @AuraEnabled
        public List<SpecRow> specifications;
    }

    public class SpecRow {

        @AuraEnabled
        public String label;

        @AuraEnabled
        public String value;
    }
}
