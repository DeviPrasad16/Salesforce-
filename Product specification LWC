<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>

    <targets>
          <target>lightningCommunity__Default</target>
        <target>lightningCommunity__Page</target>
        <target>lightning__RecordPage</target>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
    </targets>
</LightningComponentBundle>  

<template>

    <template if:true={product}>

        <div class="product-card">

          
            <div class="card-section">

                <div class="section-head" onclick={handleToggle}>

                    <h4 class="section-title">
                        <lightning-icon
                            icon-name="utility:list"
                            size="xx-small">
                        </lightning-icon>

                        Product specifications
                    </h4>

                    <lightning-icon
                        icon-name="utility:chevrondown"
                        size="xx-small"
                        class={specsChevClass}>
                    </lightning-icon>

                </div>

                <template if:true={specsOpen}>

                    <div class="section-body animate-fade-in">

                        <template
                            if:true={hasSpecifications}>

                            <template
                                for:each={product.specifications}
                                for:item="spec">

                                <div
                                    key={spec.label}
                                    class="spec-row">

                                    <span class="spec-lbl">
                                        {spec.label}
                                    </span>

                                    <span class="spec-val">
                                        {spec.value}
                                    </span>

                                </div>

                            </template>

                        </template>

                        <template if:false={hasSpecifications}>
                            <div class="description-text">
                                No specifications available.
                            </div>
                        </template>

                    </div>

                </template>

            </div>

           
            <div class="card-section">

                <div
                    class="section-head"
                    onclick={handleDescriptionToggle}>

                    <h4 class="section-title">

                        <lightning-icon
                            icon-name="utility:description"
                            size="xx-small">
                        </lightning-icon>

                        Description

                    </h4>

                    <lightning-icon
                        icon-name="utility:chevrondown"
                        size="xx-small"
                        class={descriptionChevClass}>
                    </lightning-icon>

                </div>

                <template if:true={descriptionOpen}>

                    <div class="section-body animate-fade-in">

                        <template if:true={hasDescription}>

                            <div class="description-text">

                                <lightning-formatted-rich-text
                                    value={product.description}>
                                </lightning-formatted-rich-text>

                            </div>

                        </template>

                        <template if:false={hasDescription}>

                            <div class="description-text">
                                No description available.
                            </div>

                        </template>

                    </div>

                </template>

            </div>

        </div>

    </template>

    <template if:true={error}>
        <div class="slds-text-color_error slds-p-around_medium">
            Unable to load product information.
        </div>
    </template>

</template>


import { LightningElement, wire } from 'lwc';
import { CurrentPageReference } from 'lightning/navigation';
import getProductDetails from '@salesforce/apex/ProductController.getProductDetails';

export default class ProductSpecifications extends LightningElement {

    product;
    error;
    productId;

    specsOpen = true;
    descriptionOpen = false;

    @wire(CurrentPageReference)
    handlePageReference(pageRef) {

        if (!pageRef || this.productId) {
            return;
        }

        const recordId =
            pageRef.attributes?.recordId ??
            pageRef.state?.recordId;

        if (!recordId) {
            console.warn(
                'ProductSpecifications: Unable to determine Product Id.'
            );
            return;
        }

        this.productId = recordId;
        this.loadProduct();
    }

    async loadProduct() {

        try {

            const result = await getProductDetails({
                productId: this.productId
            });

            this.product = result;
            this.error = undefined;

        } catch (error) {

            this.error = error;
            this.product = undefined;

            console.error(
                'Failed to load product details',
                error
            );
        }
    }

    handleToggle() {
        this.specsOpen = !this.specsOpen;
    }

    handleDescriptionToggle() {
        this.descriptionOpen = !this.descriptionOpen;
    }

    get specsChevClass() {
        return this.specsOpen ? 'rotate' : '';
    }

    get descriptionChevClass() {
        return this.descriptionOpen ? 'rotate' : '';
    }

    get hasSpecifications() {
        return (
            Array.isArray(this.product?.specifications) &&
            this.product.specifications.length > 0
        );
    }

    get hasDescription() {
        return Boolean(this.product?.description);
    }
}

.product-card {
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 0.5rem;
    overflow: hidden;
    font-family: 'Salesforce Sans', Arial, sans-serif;
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    box-sizing: border-box;
}


.card-section {
    padding: 1.125rem 1.25rem;
    border-bottom: 1px solid #e5e5e5;
}
.card-section:last-child {
    border-bottom: none;
}

.section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    user-select: none;
    min-height: 36px;
    gap: 0.5rem;
}
.section-head:hover .section-title {
    color: #0176d3;
}
.section-head:active {
    opacity: 0.7;
}

.section-title {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: #181818;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
    transition: color 0.15s;
}

.chev {
    transition: transform 0.25s ease;
    color: #b0adab;
    flex-shrink: 0;
}
.chev.open {
    transform: rotate(180deg);
}

.section-body {
    margin-top: 0.75rem;
}

.spec-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 0.625rem 0;
    border-bottom: 1px solid #f3f3f3;
    font-size: 0.8125rem;
    line-height: 1.45;
}
.spec-row:last-child {
    border-bottom: none;
}

.spec-lbl {
    color: #706e6b;
    flex-shrink: 0;
}

.spec-val {
    color: #181818;
    font-weight: 500;
    text-align: right;
    word-break: break-word;
    min-width: 0;
    max-width: 65%;
}

.spec-val a {
    color: #0176d3;
    text-decoration: none;
}
.spec-val a:hover {
    text-decoration: underline;
}


.description-text {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: #444;
}
.animate-fade-in {
    animation: fadeIn 0.25s ease-out;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
}


@media (max-width: 768px) {
    .product-card {
        max-width: 100%;
        border-radius: 0.375rem;
    }

    .card-section {
        padding: 1rem 1rem;
    }

    .spec-val {
        max-width: 60%;
    }
}

@media (max-width: 480px) {
    .product-card {
        border-radius: 0.375rem;
        border-left: none;
        border-right: none;
    }

    .card-section {
        padding: 0.875rem 0.875rem;
    }

    .section-head {
        min-height: 40px;
    }

    .section-title {
        font-size: 0.875rem;
    }

    .spec-row {
        flex-direction: column;
        align-items: stretch;
        gap: 0.125rem;
        padding: 0.625rem 0;
    }

    .spec-lbl {
        font-size: 0.75rem;
        color: #706e6b;
    }

    .spec-val {
        font-size: 0.8125rem;
        text-align: left;
        max-width: 100%;
        font-weight: 500;
    }
}


@media (max-width: 360px) {
    .card-section {
        padding: 0.75rem 0.75rem;
    }

    .spec-row {
        padding: 0.5rem 0;
    }

    .description-text {
        font-size: 0.78125rem;
    }
} 
